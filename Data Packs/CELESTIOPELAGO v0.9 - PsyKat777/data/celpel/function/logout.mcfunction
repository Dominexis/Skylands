execute if entity @s[nbt={Inventory:[{id:"minecraft:iron_shovel"}]}] run give @r[x=-1775,y=226,z=-6376,distance=..250,team=sl.player,tag=!celpel.targeted] iron_shovel[custom_name=[{"text":"Repeater Plow","italic":false,"color":"white"}],lore=[[{"text":"A plow of sorts that is capable of scooping up","italic":false}],[{"text":"redstone repeaters.","italic":false}]],can_break=[{blocks:repeater}],unbreakable={},item_model="repeater_plow"]

