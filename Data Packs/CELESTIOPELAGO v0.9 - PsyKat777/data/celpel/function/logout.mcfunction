## This function runs as and at a player when they log out of the plot

# Ascertains which player is targeted, so that their items will be given to other players, not back to themselves
tag @s add celpel.targeted

# Detects which items the player has (minus the telepad boots), and gives them to the other players randomly to prevent softlocking when a
# player with necessary items decides to leave
execute if entity @s[nbt={Inventory:[{id:"minecraft:lever"}]}] run give @r[x=-1775,y=226,z=-6376,distance=..250,team=sl.player,tag=!celpel.targeted] lever[custom_name=[{"text":"Old-Fashioned Lever","italic":false,"color":"dark_green"}],lore=[[{"text":"An old-fashioned lever. It has an Industrial","italic":false}],[{"text":"Revolution-esque aesthetic, an aesthetic that","italic":false}],[{"text":"is experiencing a revival due to a recent","italic":false}],[{"text":"renaissance of sorts.","italic":false}]],can_place_on=[{blocks:polished_andesite}]]
execute if entity @s[nbt={Inventory:[{id:"minecraft:bow"}]}] run give @r[x=-1775,y=226,z=-6376,distance=..250,team=sl.player,tag=!celpel.targeted] bow[custom_name=[{"text":"Zygartia Quality Bow","italic":false}],lore=[[{"text":"A high-quality bow created by the Republic of","italic":false}],[{"text":"Zygartia. It can shoot arrows because it's a","italic":false}],[{"text":"bow. Made with love, hence its quality.","italic":false}]],unbreakable={}]
execute if entity @s[nbt={Inventory:[{id:"minecraft:spectral_arrow"}]}] run give @r[x=-1775,y=226,z=-6376,distance=..250,team=sl.player,tag=!celpel.targeted] spectral_arrow[custom_name=[{"text":"Duplicator Arrow","italic":false}],lore=[[{"text":"An arrow made of an unusual material. When","italic":false}],[{"text":"shot, it copies itself, shooting one copy and","italic":false}],[{"text":"leaving you with the other copy.","italic":false}]]]
