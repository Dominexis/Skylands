# Makes sure that the repeaters always teleport to the player with the plow/shovel and have the right nbt and whatnot
execute as @e[type=minecraft:item,nbt={Item:{id:"minecraft:repeater"}},x=-1775,y=226,z=-6376,distance=..250] run tp @s @r[nbt={Inventory:[{id:"minecraft:iron_shovel"}]},x=-1775,y=226,z=-6376,distance=..250,team=sl.player]
execute as @e[type=minecraft:item,nbt={Item:{id:"minecraft:repeater"}}, x=-1775,y=226,z=-6376,distance=..250] run data merge entity @s {Item:{components:{"minecraft:lore":[[{"text":"An unusual electrical component that is only","italic":false}],[{"text":"compatible with an esoteric brand of circuitry.","italic":false}],[{"text":"Able to extend the power from redstone wire.","italic":false}]], "minecraft:can_place_on":{blocks:"minecraft:chiseled_deepslate"}}}}