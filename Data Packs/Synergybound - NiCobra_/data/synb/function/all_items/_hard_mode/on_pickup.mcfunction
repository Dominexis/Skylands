title @s times 10 80 30
title @s title {text:"Hard mode enabled",bold:true,color:"red"}
execute if score @s synb.IEItemCount._hard_mode matches 2 run title @s subtitle {text:"...again ???",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 3 run title @s subtitle {text:"...and again ????",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 4 run title @s subtitle {text:"Bro what are you doing",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 5 run title @s subtitle {text:"STOP THAT",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 6 run title @s subtitle {text:"But why ?",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 7 run title @s subtitle {text:"Do you realize you will die in 1 hit ?",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 8 run title @s subtitle {text:"You will be broke as well",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 9 run title @s subtitle {text:"Speedrun categories be like",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 10 run title @s subtitle {text:"Just play blindfolded at that point",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 11 run title @s subtitle {text:"I don't think this run will be fun",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 12 run title @s subtitle {text:"Do you realize adding more barely do anything ?",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 13 run title @s subtitle {text:"Just press the start arena button damn it",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 14 run title @s subtitle {text:"Anyways I'm tired of speaking",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 15..16 run title @s subtitle {text:"Goodnight",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 17 run title @s subtitle {text:"No there won't be more messages",bold:true,color:"gold"}
execute if score @s synb.IEItemCount._hard_mode matches 18.. run title @s subtitle {text:"Goodnight",bold:true,color:"gold"}